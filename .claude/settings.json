{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Skill",
      "Bash(git *)",
      "PowerShell(git *)",
      "Bash(mvn *)",
      "PowerShell(*mvn*)",
      "PowerShell($env:JAVA_HOME*)",
      "Bash(java *)",
      "Bash(javac *)",
      "PowerShell(Get-ChildItem *)",
      "PowerShell(Select-Object *)",
      "PowerShell(Select-String *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "PowerShell(Remove-Item -Recurse*)"
    ]
  }
}
